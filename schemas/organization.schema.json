{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mission Systems Organization Schema",
  "description": "Defines organizations participating in the Mission Systems ecosystem.",
  "type": "object",

  "required": [
    "organizationId",
    "name",
    "status",
    "organizationType"
  ],

  "properties": {

    "identity": {
      "type": "object",
      "properties": {
        "organizationId": {
          "type": "string"
        },
        "msid": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "legalName": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "created": {
          "type": "string",
          "format": "date-time"
        },
        "updated": {
          "type": "string",
          "format": "date-time"
        }
      }
    },

    "classification": {
      "type": "object",
      "properties": {
        "organizationType": {
          "type": "string",
          "enum": [
            "Company",
            "LLC",
            "Nonprofit",
            "Government",
            "Research Institute",
            "University",
            "School",
            "Foundation",
            "Community",
            "Partnership",
            "Other"
          ]
        }
      }
    },

    "profile": {
      "type": "object",
      "properties": {
        "mission": {
          "type": "string"
        },
        "vision": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "website": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "location": {
          "type": "string"
        }
      }
    },

    "leadership": {
      "type": "object",
      "properties": {
        "founder": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "stewards": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },

    "relationships": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },

    "projects": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },

    "researchPrograms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },

    "history": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },

    "notes": {
      "type": "string"
    }
  }
}
