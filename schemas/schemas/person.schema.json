{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mission Systems Person Schema",
  "description": "Defines contributors, researchers, developers, reviewers, and other participants in the Mission Systems ecosystem.",
  "type": "object",

  "required": [
    "personId",
    "displayName",
    "status"
  ],

  "properties": {

    "identity": {
      "type": "object",
      "properties": {
        "personId": {
          "type": "string"
        },
        "msid": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "created": {
          "type": "string",
          "format": "date-time"
        },
        "updated": {
          "type": "string",
          "format": "date-time"
        }
      }
    },

    "profile": {
      "type": "object",
      "properties": {
        "organization": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "biography": {
          "type": "string"
        },
        "expertise": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },

    "roles": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Founder",
          "Maintainer",
          "Developer",
          "Researcher",
          "Reviewer",
          "Author",
          "Editor",
          "Contributor",
          "Community Member",
          "Advisor",
          "Student",
          "Other"
        ]
      }
    },

    "contributions": {
      "type": "object",
      "properties": {
        "missions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "projects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "research": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "software": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "documents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },

    "relationships": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },

    "history": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },

    "notes": {
      "type": "string"
    }
  }
}
